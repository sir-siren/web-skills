{
    "name": "web-skills",
    "description": "A visual overview of useful skills to learn as a web developer",
    "type": "module",
    "license": "MIT",
    "author": "Andreas Mehlsen",
    "bugs": {
        "url": "https://github.com/andreasbm/web-skills/issues"
    },
